# LUP configuration file
#
# Copy to ~/.config/lup/config.toml for global settings, or to
# <project>/.lup/config.toml for per-project overrides.

[active]
# Generator profile used by lup tui, lup summarise, and lup document.
agent = "local"
level = "medium" # low, medium, high, xhigh

[llm]
# Backward-compatible OpenAI-compatible settings used by lookup/index embeddings.
base_url = "http://localhost:11434/v1"
chat_model = "qwen2.5-coder:7b"
embed_model = "nomic-embed-text"
api_key = ""
timeout_secs = 120

[agents.local]
# Ollama, vLLM, LM Studio, OpenAI-compatible gateways.
provider = "openai_compatible"
base_url = "http://localhost:11434/v1"
model = "qwen2.5-coder:7b"
embed_model = "nomic-embed-text"
api_key = ""
api_key_env = ""
timeout_secs = 120

[agents.opencode_zen]
# OpenCode Zen pay-as-you-go gateway. Set OPENCODE_API_KEY or api_key.
provider = "opencode_zen"
model = "opencode/gpt-5.5"
api_key = ""
api_key_env = "OPENCODE_API_KEY"
timeout_secs = 120

[agents.cursor]
# Cursor Cloud Agent backend. Set CURSOR_API_KEY or api_key.
provider = "cursor_agent"
base_url = "https://api.cursor.com/v1"
model = "composer-2"
api_key = ""
api_key_env = "CURSOR_API_KEY"
timeout_secs = 600
mode = "agent"

[embedding]
# Keep embeddings separate so agent-backed summarisation can still use local lookup/indexing.
provider = "openai_compatible"
base_url = "http://localhost:11434/v1"
model = "nomic-embed-text"
api_key = ""
api_key_env = ""
timeout_secs = 120

[summarisation]
query = "Summarise this document for lup. Return only the JSON object matching the schema."
system_prompt = ""
max_symbols_per_prompt = 25
body_budget = 8000
temperature = 0.20

[apps]
editor = ""
opener = ""

[keybinds]
up = "up"
down = "down"
left = "left"
right = "right"
confirm = "enter"
page_up = "pgup"
page_down = "pgdown"
jump_top = "home"
jump_bottom = "end"
quit = "q"
edit = "e"
options = "o"
switch_agent = "m"
switch_level = "l"
regenerate = "r"
show_hints = "?"
show_updates = "U"

[index]
top_k = 5
auto_summarise = true
concurrency = 2

[updates]
disable_checks = false
current_commit = ""
repo_path = ""
terminal = ""
